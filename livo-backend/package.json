{
  "name": "livo-backend",
  "version": "1.0.0",
  "scripts": {
    "build:gateway": "tsc -p apps/api-gateway/tsconfig.app.json",
    "build:hero": "tsc -p apps/hero-service/tsconfig.app.json",
    "build:events": "tsc -p apps/events-service/tsconfig.app.json",
    "build:games": "tsc -p apps/games-service/tsconfig.app.json",
    "build:teams": "tsc -p apps/teams-service/tsconfig.app.json",
    "build:champions": "tsc -p apps/champions-service/tsconfig.app.json",
    "build:gallery": "tsc -p apps/gallery-service/tsconfig.app.json",
    "build:rules": "tsc -p apps/rules-service/tsconfig.app.json",
    "build:tournament": "tsc -p apps/tournament-service/tsconfig.app.json",
    "build:cta": "tsc -p apps/cta-service/tsconfig.app.json",
    "start:gateway": "node dist/apps/api-gateway/apps/api-gateway/src/main",
    "dev:gateway": "ts-node -r tsconfig-paths/register apps/api-gateway/src/main.ts",
    "dev:hero": "ts-node -r tsconfig-paths/register apps/hero-service/src/main.ts",
    "dev:events": "ts-node -r tsconfig-paths/register apps/events-service/src/main.ts",
    "dev:games": "ts-node -r tsconfig-paths/register apps/games-service/src/main.ts",
    "dev:teams": "ts-node -r tsconfig-paths/register apps/teams-service/src/main.ts",
    "dev:champions": "ts-node -r tsconfig-paths/register apps/champions-service/src/main.ts",
    "dev:gallery": "ts-node -r tsconfig-paths/register apps/gallery-service/src/main.ts",
    "dev:rules": "ts-node -r tsconfig-paths/register apps/rules-service/src/main.ts",
    "dev:tournament": "ts-node -r tsconfig-paths/register apps/tournament-service/src/main.ts",
    "dev:about": "ts-node -r tsconfig-paths/register apps/about-service/src/main.ts",
    "dev:cta": "ts-node -r tsconfig-paths/register apps/cta-service/src/main.ts",
    "dev:all": "concurrently \"npm run dev:gateway\" \"npm run dev:hero\" \"npm run dev:about\" \"npm run dev:events\" \"npm run dev:games\" \"npm run dev:teams\" \"npm run dev:champions\" \"npm run dev:gallery\" \"npm run dev:rules\" \"npm run dev:tournament\" \"npm run dev:cta\"",
    "build:all": "npm run build:gateway && npm run build:hero && npm run build:events && npm run build:games && npm run build:teams && npm run build:champions && npm run build:gallery && npm run build:rules && npm run build:tournament && npm run build:cta",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:rebuild": "docker-compose up -d --build"
  },
  "dependencies": {
    "@livo/common": "file:./libs/common",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/microservices": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/throttler": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "kafkajs": "^2.2.4",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcryptjs": "^2.4.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^3.0.0",
    "@types/passport-local": "^1.0.0",
    "concurrently": "^8.2.2",
    "rimraf": "^5.0.0",
    "ts-loader": "^9.4.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.0.0"
  }
}
